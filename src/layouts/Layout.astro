---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const site = "https://sonodos.studio";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{t("meta.title")}</title>
    <meta name="description" content={t("meta.description")} />
    <link rel="alternate" hreflang="en" href={site} />
    <link rel="alternate" hreflang="es" href={`${site}/es/`} />
    <link rel="alternate" hreflang="x-default" href={site} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="cur"></div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --paper: #eceae3;
    --ink: #141210;
    --ochre: #c49520;
    --red: #c03b24;
    --teal: #1e3835;
    --lt: #838383;
    --mid: #8a857e;

    --f-disp: "Syne", sans-serif;
    --f-mono: "IBM Plex Mono", monospace;

    --u: 8px; /* base unit */
  }

  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    background-color: #eceae3;
    background-image: url("/beige-paper.png");
    color: var(--ink);
    font-family: var(--f-disp);
    cursor: none;
    overflow-x: hidden;
  }

  /* ─── Cursor ─────────────────────────────── */
  #cur {
    position: fixed;
    z-index: 9000;
    width: 8px;
    height: 8px;
    background: var(--ink);
    pointer-events: none;
    transform: translate(-4px, -4px);
    transition:
      width 0.18s ease,
      height 0.18s ease,
      background 0.18s ease;
    mix-blend-mode: multiply;
  }
  #cur::before,
  #cur::after {
    content: "";
    position: absolute;
    background: var(--ink);
  }
  #cur::before {
    width: 1px;
    height: 18px;
    top: -5px;
    left: 3.5px;
  }
  #cur::after {
    width: 18px;
    height: 1px;
    left: -5px;
    top: 3.5px;
  }
  #cur.big {
    width: 24px;
    height: 24px;
    transform: translate(-12px, -12px);
    background: transparent;
    border: 1px solid var(--ink);
  }
  #cur.big::before {
    top: -6px;
    left: 11.5px;
  }
  #cur.big::after {
    left: -6px;
    top: 11.5px;
  }
  .inv #cur,
  .inv #cur::before,
  .inv #cur::after {
    background: var(--paper);
  }
  .inv #cur.big {
    border-color: var(--paper);
    background: transparent;
  }

  /* ─── Shared helpers ─────────────────────── */
  .mono {
    font-family: var(--f-mono);
    font-weight: 300;
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }
  .rule-h {
    width: 100%;
    height: 1px;
    background: var(--ink);
  }
  .rule-v {
    height: 100%;
    width: 1px;
    background: var(--ink);
  }
  /* ═══ RESPONSIVE ═════════════════════════ */
</style>
<script>
  import { lerp } from "../scripts/utils.js";

  const curEl = document.getElementById("cur");
  let cx0 = 0,
    cy0 = 0,
    ctX = 0,
    ctY = 0;
  document.addEventListener("mousemove", (e) => {
    ctX = e.clientX;
    ctY = e.clientY;
  });
  (function curLoop() {
    requestAnimationFrame(curLoop);
    cx0 = lerp(cx0, ctX, 0.14);
    cy0 = lerp(ctY, cy0, 0.14);
    curEl.style.transform = `translate(${cx0 - 4}px,${cy0 - 4}px)`;
  })();

  function initCursor() {
    document
      .querySelectorAll(
        "a,button,.art-layer-item,.exp-col,.ps-cell,.art-layer-dot",
      )
      .forEach((el) => {
        el.addEventListener("mouseenter", () => curEl.classList.add("big"));
        el.addEventListener("mouseleave", () => curEl.classList.remove("big"));
      });
  }

  initCursor();

  document.addEventListener("astro:page-load", initCursor);
</script>

<script>
  new IntersectionObserver(
    (es) =>
      es.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("vis");
      }),
    { threshold: 0.08 },
  ).observe(document.querySelector("#experiments"));

  document.querySelectorAll(".exp-col").forEach((c) => {
    new IntersectionObserver(
      (es) => {
        if (es[0].isIntersecting) c.classList.add("vis");
      },
      { threshold: 0.08 },
    ).observe(c);
  });

  document.addEventListener("astro:page-load", () => {
    new IntersectionObserver(
      (es) =>
        es.forEach((e) => {
          if (e.isIntersecting) e.target.classList.add("vis");
        }),
      { threshold: 0.08 },
    ).observe(document.querySelector("#experiments"));

    document.querySelectorAll(".exp-col").forEach((c) => {
      new IntersectionObserver(
        (es) => {
          if (es[0].isIntersecting) c.classList.add("vis");
        },
        { threshold: 0.08 },
      ).observe(c);
    });
  });
</script>
