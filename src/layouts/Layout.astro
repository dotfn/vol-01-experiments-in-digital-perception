---
import Cursor from "../components/Cursor.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const site = "https://sonodos.studio";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{t("meta.title")}</title>
    <meta name="description" content={t("meta.description")} />
    <link rel="alternate" hreflang="en" href={site} />
    <link rel="alternate" hreflang="es" href={`${site}/es/`} />
    <link rel="alternate" hreflang="x-default" href={site} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Cursor />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --paper: #eceae3;
    --ink: #141210;
    --ochre: #c49520;
    --red: #c03b24;
    --teal: #1e3835;
    --lt: #838383;
    --mid: #8a857e;

    --f-disp: "Syne", sans-serif;
    --f-mono: "IBM Plex Mono", monospace;

    --u: 8px; /* base unit */
  }

  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    background-color: #eceae3;
    background-image: url("/beige-paper.png");
    color: var(--ink);
    font-family: var(--f-disp);
    cursor: none;
    overflow-x: hidden;
  }


  /* ─── Shared helpers ─────────────────────── */
  .mono {
    font-family: var(--f-mono);
    font-weight: 300;
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }
  .rule-h {
    width: 100%;
    height: 1px;
    background: var(--ink);
  }
  .rule-v {
    height: 100%;
    width: 1px;
    background: var(--ink);
  }
  canvas {
  user-select: none;
  -webkit-user-select: none;
  -webkit-touch-callout: none;
  -webkit-tap-highlight-color: transparent;
  
}
</style>


