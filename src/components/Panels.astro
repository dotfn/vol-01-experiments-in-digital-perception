        <p set:html={t('panel.layer05.body.1')}></p>
        <p set:html={t('panel.layer05.body.2')}></p>
      </div>
      <div class="p-foot">
        <a href={`mailto:${t('panel.layer05.foot.email')}`} class="p-link">{t('panel.layer05.foot.email')}</a><br /><a
          href="#"
          class="p-link">{t('panel.layer05.foot.link')}</a>
      </div>
    </div>
  </div>

  <div class="art-s-bot">
    <div class="art-layer-list">
      <div class="art-layer-item" data-open-panel="0">
        <div class="art-layer-dot" style="background:var(--teal)"></div>
        {t('artwork.layer.exhibition')}
