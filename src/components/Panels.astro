</div>


<style>
  /* ═══════════════════════════════════════
   PANELS
   ═══════════════════════════════════════ */
  #backdrop {
    position: fixed;
    inset: 0;
    z-index: 190;
    background: rgba(20, 18, 16, 0.22);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease;
  }
  #backdrop.vis {
    opacity: 1;
    pointer-events: all;
  }

  .panel {
    position: fixed;
    top: 0;
    right: 0;
    width: min(500px, 100vw);
    height: 100vh;
    background: var(--paper);
    border-left: 1px solid var(--ink);
    transform: translateX(100%);
    transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 200;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .panel::-webkit-scrollbar {
    display: none;
  }
  .panel.open {
    transform: translateX(0);
  }

  .p-in {
    padding: 56px 48px;
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }
  .p-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }
  .p-tag {
    font-family: var(--f-mono);
    font-size: 8.5px;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--mid);
  }
  .p-close {
    background: none;
    border: none;
    color: var(--mid);
    font-family: var(--f-mono);
    font-size: 16px;
    cursor: none;
    line-height: 1;
    padding: 2px 6px;
    transition: color 0.2s;
  }
  .p-close:hover {
    color: var(--ink);
  }
  .p-num {
    font-family: var(--f-disp);
    font-size: 120px;
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: rgba(20, 18, 16, 0.05);
    margin-bottom: -12px;
  }
  .p-title {
    font-family: var(--f-disp);
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 32px;
  }
  .p-title :global(em) {
    font-style: normal;
    font-weight: 400;
    color: var(--mid);
  }
  .p-rule {
    height: 1px;
    background: rgba(20, 18, 16, 0.15);
    margin-bottom: 28px;
  }
  .p-body {
    font-size: clamp(13px, 1vw, 15px);
    font-weight: 400;
    line-height: 1.88;
    color: var(--mid);
    flex: 1;
  }
  .p-body p {
    margin-bottom: 18px;
  }
  .p-body p:last-child {
    margin-bottom: 0;
  }
  .p-body em {
    color: var(--ink);
    font-style: normal;
    font-weight: 600;
  }
  .p-foot {
    margin-top: 44px;
    padding-top: 20px;
    border-top: 1px solid rgba(20, 18, 16, 0.12);
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--mid);
  }
  .p-link {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--f-mono);
    font-size: 8.5px;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid rgba(20, 18, 16, 0.2);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }
  .p-link:hover {
    border-color: var(--ink);
  }
  .art-s-bot {
    padding: 20px;
  }
  .art-layer-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .art-layer-item {
    padding: 12px 0;
    border-bottom: 1px solid rgba(20, 18, 16, 0.1);
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    text-decoration: underline;
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mid);
    cursor: none;
    transition: color 0.25s;
  }
  .art-layer-item:last-child {
    border-bottom: none;
  }
  .art-layer-item:hover {
    color: var(--ink);
  }
  .art-layer-dot {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  .art-layer-item:hover .art-layer-dot {
    transform: scale(1.5);
  }
</style>

<script>
  import { $activePanel } from '../stores/panelStore';

  const bdrop = document.getElementById('backdrop');

  // ── Reacciona a cambios en el store ──
  $activePanel.subscribe(id => {
    // Cerrar todos primero
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('open'));

    if (id >= 0) {
      document.getElementById(`panel-${id}`)?.classList.add('open');
      bdrop?.classList.add('vis');
    } else {
      bdrop?.classList.remove('vis');
    }
  });

  // ── Cerrar: solo escribe -1 al store ──
  function closePanel() {
    $activePanel.set(-1);
  }

  // ── Layer list: escribe al store ──
  document.querySelectorAll<HTMLElement>('[data-open-panel]').forEach(el => {
    el.addEventListener('click', () => {
      const id = Number(el.dataset.openPanel);
      $activePanel.set(id);
    });
  });

  bdrop?.addEventListener('click', closePanel);
  document.querySelectorAll('.p-close').forEach(b => b.addEventListener('click', closePanel));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closePanel(); });
  document.getElementById('go-exh')?.addEventListener('click', closePanel);
</script>