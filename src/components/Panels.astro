---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- ─── PANELS ────────────────────────────────────────── -->
<div>
  <div id="backdrop"></div>

  <div class="panel" id="panel-0">
    <div class="p-in">
      <div class="p-head">
        <div class="p-tag">{t('panel.layer01.tag')}</div><button
          class="p-close"
          data-close="0">×</button>
      </div>
      <div class="p-num">01</div>
      <h2 class="p-title" set:html={t('panel.layer01.title')}></h2>
      <div class="p-rule"></div>
      <div class="p-body">
        <p set:html={t('panel.layer01.body.1')}></p>
        <p set:html={t('panel.layer01.body.2')}></p>
        <p set:html={t('panel.layer01.body.3')}></p>
      </div>
      <div class="p-foot">{t('panel.layer01.foot')}</div>
    </div>
  </div>

  <div class="panel" id="panel-1">
    <div class="p-in">
      <div class="p-head">
        <div class="p-tag">{t('panel.layer02.tag')}</div><button
          class="p-close"
          data-close="1">×</button>
      </div>
      <div class="p-num">02</div>
      <h2 class="p-title" set:html={t('panel.layer02.title')}></h2>
      <div class="p-rule"></div>
      <div class="p-body">
        <p set:html={t('panel.layer02.body.1')}></p>
        <p set:html={t('panel.layer02.body.2')}></p>
        <p set:html={t('panel.layer02.body.3')}></p>
      </div>
      <div class="p-foot">{t('panel.layer02.foot')}</div>
    </div>
  </div>

  <div class="panel" id="panel-2">
    <div class="p-in">
      <div class="p-head">
        <div class="p-tag">{t('panel.layer03.tag')}</div><button
          class="p-close"
          data-close="2">×</button>
      </div>
      <div class="p-num">03</div>
      <h2 class="p-title" set:html={t('panel.layer03.title')}></h2>
      <div class="p-rule"></div>
      <div class="p-body">
        <p set:html={t('panel.layer03.body.1')}></p>
        <p set:html={t('panel.layer03.body.2')}></p>
        <p set:html={t('panel.layer03.body.3')}></p>
      </div>
      <div class="p-foot">{t('panel.layer03.foot')}</div>
    </div>
  </div>

  <div class="panel" id="panel-3">
    <div class="p-in">
      <div class="p-head">
        <div class="p-tag">{t('panel.layer04.tag')}</div><button
          class="p-close"
          data-close="3">×</button>
      </div>
      <div class="p-num">04</div>
      <h2 class="p-title" set:html={t('panel.layer04.title')}></h2>
      <div class="p-rule"></div>
      <div class="p-body">
        <p set:html={t('panel.layer04.body.1')}></p>
        <p set:html={t('panel.layer04.body.2')}></p>
        <p set:html={t('panel.layer04.body.3')}></p>
        <p set:html={t('panel.layer04.body.4')}></p>
        <p set:html={t('panel.layer04.body.5')}></p>
