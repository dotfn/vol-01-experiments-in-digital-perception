  <div class="panel" id="panel-4">
    <div class="p-in">
      <div class="p-head">
        <div class="p-tag">{t('panel.layer05.tag')}</div><button
          class="p-close"
          data-close="4">×</button>
      </div>
      <div class="p-num">05</div>
      <h2 class="p-title" set:html={t('panel.layer05.title')}></h2>
      <div class="p-rule"></div>
