---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;
---

<div class="art-sidebar art-sidebar-r">
  <div class="art-s-top">
    <div>
      <div class="art-index">{t('artwork.properties')}</div>
      <div class="art-sidebar-title" style="margin-bottom:16px">
        {t('artwork.currentState')}
      </div>
      <div class="art-layer-list" id="prop-list">
        <div class="art-layer-item">
          <span id="prop-pal" class="prop-label">{t('artwork.palette')} I</span>
        </div>
        <div class="art-layer-item">
          <span id="prop-mode" class="prop-label">{t('artwork.ambient')}</span>
        </div>
        <div class="art-layer-item">
          <span id="prop-layers" class="prop-label">5 {t('artwork.layers')}</span>
        </div>
      </div>
    </div>
  </div>
  <div class="art-s-bot">
    <div class="art-sidebar-desc">{t('artwork.canvasHint')}</div>
  </div>
</div>

<style>
  .art-sidebar {
    display: flex;
    flex-direction: column;
  }
  .art-sidebar-r {
    border-left: 1px solid var(--ink);
  }
  .art-s-top {
    flex: 1;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-bottom: 1px solid var(--ink);
  }
  .art-s-bot {
    padding: 20px;
  }
  .art-index {
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 12px;
  }
  .art-sidebar-title {
    font-family: var(--f-disp);
    font-size: clamp(11px, 0.9vw, 14px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .art-sidebar-desc {
    font-size: clamp(10px, 0.8vw, 12px);
    font-weight: 400;
    line-height: 1.7;
    color: var(--mid);
    margin-top: 12px;
  }
  .art-layer-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .art-layer-item {
    padding: 12px 0;
    border-bottom: 1px solid rgba(20, 18, 16, 0.1);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .art-layer-item:last-child {
    border-bottom: none;
  }
  .prop-label {
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mid);
  }

  @media (max-width: 900px) {
    .art-sidebar {
      display: none;
    }
  }
</style>