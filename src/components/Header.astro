---
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<header id="header">
  <div class="hd-cell">{t('header.vol')} — {year}</div>
  <div class="hd-cell">{t('header.studio')}</div>
  <div class="hd-cell"><span id="hd-sub-text">{t('header.subtitle')}</span><LanguagePicker /></div>
</header>
<style>
    #header {
  width:100%; height:40px;
  display:grid; grid-template-columns:1fr auto 1fr;
  border-bottom:1px solid var(--ink);
  position: sticky; top:0; z-index: 100;
  background: var(--paper);
}
.hd-cell {
  display:flex; align-items:center; padding:0 24px;
  font-family:var(--f-mono); font-size:9px; font-weight:300;
  letter-spacing:.28em; text-transform:uppercase; color:var(--mid);
  border-right:1px solid var(--ink);
}
.hd-cell:last-child { border-right:none; justify-content:flex-end; }
.hd-cell:nth-child(2) { justify-content:center; color:var(--ink); font-weight:400; letter-spacing:.18em; font-size:10px; }
  @media (max-width: 560px) {

    #header {
      grid-template-columns: 1fr;
    }
    .hd-cell:first-child,
    .hd-cell:last-child {
      display: none;
    }
    .hd-cell:nth-child(2) {
      border-right: none;
    }
  }
</style>