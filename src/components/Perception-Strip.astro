---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div id="perception-strip">
  <div class="ps-cell">
    <div class="ps-inner"></div><span class="ps-label"
      >{t("perception.strip.onTeal")}</span
    >
  </div>
  <div class="ps-cell">
    <div class="ps-inner"></div><span class="ps-label"
      >{t("perception.strip.onOchre")}</span
    >
  </div>
  <div class="ps-cell">
    <div class="ps-inner"></div><span class="ps-label"
      >{t("perception.strip.onPaper")}</span
    >
  </div>
  <div class="ps-cell">
    <div class="ps-inner"></div><span class="ps-label"
      >{t("perception.strip.onRed")}</span
    >
  </div>
  <div class="ps-cell">
    <div class="ps-inner"></div><span class="ps-label"
      >{t("perception.strip.onInk")}</span
    >
  </div>
</div>
<div id="ps-caption">
  ↑ {t("perception.strip.caption")}
</div>

<style>
  /* ─── Perception demo strip ─── */
  #perception-strip {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-bottom: 1px solid var(--ink);
    height: 72px;
    cursor: crosshair;
  }
  .ps-cell {
    border-right: 1px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: background 0.4s ease;
  }
  .ps-cell:last-child {
    border-right: none;
  }
  /* The SAME small square in every cell — identical absolute color */
  .ps-inner {
    width: 24px;
    height: 24px;
    background: #a0988f; /* same color in all cells */
    transition: transform 0.35s ease;
    flex-shrink: 0;
  }
  /* Different backgrounds → same grey appears different */
  .ps-cell:nth-child(1) {
    background: var(--teal);
  }
  .ps-cell:nth-child(2) {
    background: var(--ochre);
  }
  .ps-cell:nth-child(3) {
    background: var(--paper);
  }
  .ps-cell:nth-child(4) {
    background: var(--red);
  }
  .ps-cell:nth-child(5) {
    background: var(--ink);
  }

  .ps-cell:hover .ps-inner {
    transform: scale(1.3);
  }

  .ps-label {
    position: absolute;
    bottom: 8px;
    width: 100%;
    text-align: center;
    font-family: var(--f-mono);
    font-size: 7px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .ps-cell:nth-child(1) .ps-label {
    color: rgba(236, 234, 227, 0.4);
  }
  .ps-cell:nth-child(2) .ps-label {
    color: rgba(20, 18, 16, 0.4);
  }
  .ps-cell:nth-child(3) .ps-label {
    color: rgba(20, 18, 16, 0.28);
  }
  .ps-cell:nth-child(4) .ps-label {
    color: rgba(236, 234, 227, 0.4);
  }
  .ps-cell:nth-child(5) .ps-label {
    color: rgba(236, 234, 227, 0.35);
  }

  #ps-caption {
    text-align: center;
    padding: 14px 24px;
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mid);
    border-bottom: 1px solid var(--ink);
  }
/* ─── Perception demo strip interactions ─── */

.ps-inner {
  width: 24px;
  height: 24px;
  background: #a0988f;
  transform-origin: center;

  /* transición optimizada */
  transition:
    transform 220ms cubic-bezier(.4,0,.2,1),
    opacity 220ms cubic-bezier(.4,0,.2,1);

  will-change: transform, opacity;
}

/* cuando alguna celda está en hover, bajan todos */
#perception-strip:has(.ps-cell:hover) .ps-inner {
  opacity: .45;
  transition-delay: 40ms;
}

/* el activo recupera opacidad y escala */
.ps-cell:hover .ps-inner {
  opacity: 1;
  transform: scale(1.22);
  transition-delay: 0ms;
}
</style>
