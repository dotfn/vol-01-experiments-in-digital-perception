---
import { useTranslations } from '../i18n/utils';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<!-- ═══════════════════════════════════════════════════
     THEORY SECTION
     Inject between #artwork-section and #about in main page.
     All class names prefixed "th-" to avoid collisions.
     ═══════════════════════════════════════════════════ -->
<section id="theory">

  <!-- Header row -->
  <div class="th-header">
    <div class="th-header-l">
      <span class="th-section-n">{t('theory.section.n')}</span>
      <span class="th-section-tag">{t('theory.section.tag')}</span>
    </div>
    <div class="th-header-r">
      <div class="th-dot-row">
        <div class="th-dot" style="background:var(--teal)"></div>
        <div class="th-dot" style="background:var(--ochre)"></div>
        <div class="th-dot" style="background:var(--red)"></div>
        <div class="th-dot" style="background:var(--ink)"></div>
        <div class="th-dot" style="background:var(--lt)"></div>
      </div>
      <span>{t('theory.header.right')}</span>
    </div>
  </div>

  <!-- Main body -->
  <div class="th-body">

    <!-- LEFT: text -->
    <div class="th-left">

      <p class="th-eyebrow">{t('theory.eyebrow')}</p>

      <h2 class="th-title" set:html={t('theory.title')}></h2>

      <p class="th-intro" set:html={t('theory.intro')}></p>

      <div class="th-notes">

        <div class="th-note">
          <div class="th-note-bar" style="background:var(--teal)"></div>
          <div class="th-note-content">
            <div class="th-note-label">{t('theory.note.01.label')}</div>
            <div class="th-note-title">{t('theory.note.01.title')}</div>
            <p class="th-note-body" set:html={t('theory.note.01.body')}></p>
          </div>
        </div>

        <div class="th-note">
          <div class="th-note-bar" style="background:var(--ochre)"></div>
          <div class="th-note-content">
            <div class="th-note-label">{t('theory.note.02.label')}</div>
            <div class="th-note-title">{t('theory.note.02.title')}</div>
            <p class="th-note-body" set:html={t('theory.note.02.body')}></p>
          </div>
        </div>

        <div class="th-note">
          <div class="th-note-bar" style="background:var(--red)"></div>
          <div class="th-note-content">
            <div class="th-note-label">{t('theory.note.03.label')}</div>
            <div class="th-note-title">{t('theory.note.03.title')}</div>
            <p class="th-note-body" set:html={t('theory.note.03.body')}></p>
          </div>
        </div>

      </div>
    </div>

    <!-- Vertical rule -->
    <div class="th-rule-v"></div>

    <!-- RIGHT: geometric studies -->
    <div class="th-right">

      <!-- Study A — nested squares -->
      <div class="th-study">
        <div class="th-study-label">
          <span>{t('theory.study.a.title')}</span>
          <span>{t('theory.study.a.fig')}</span>
        </div>
        <div class="sq-diagram">
          <div class="sq-nest sq-l0">
            <div class="sq-nest sq-l1">
              <div class="sq-nest sq-l2">
                <div class="sq-nest sq-l3">
                  <div class="sq-nest sq-l4"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <p class="th-study-foot">
          {t('theory.study.a.foot')}
        </p>
      </div>

      <!-- Study B — same value, different ground -->
      <div class="th-study">
        <div class="th-study-label">
          <span>{t('theory.study.b.title')}</span>
          <span>{t('theory.study.b.fig')}</span>
        </div>
        <div class="field-row">
          <div class="field-cell"><div class="field-centre"></div></div>
          <div class="field-cell"><div class="field-centre"></div></div>
          <div class="field-cell"><div class="field-centre"></div></div>
          <div class="field-cell"><div class="field-centre"></div></div>
        </div>
        <p class="field-note">
          {t('theory.study.b.note')}
        </p>
        <p class="th-study-foot">
          {t('theory.study.b.foot')}
        </p>
      </div>

      <!-- Study C — offset tension -->
      <div class="th-study">
        <div class="th-study-label">
          <span>{t('theory.study.c.title')}</span>
          <span>{t('theory.study.c.fig')}</span>
        </div>
        <div class="sq-diagram">
          <div class="sq-nest-offset">
            <div class="sq-offset-a"></div>
            <div class="sq-offset-b"></div>
            <div class="sq-offset-c"></div>
            <div class="sq-offset-d"></div>
          </div>
        </div>
        <p class="th-study-foot">
          {t('theory.study.c.foot')}
        </p>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="th-bottom">
    <div class="th-bottom-l">
      {t('theory.bottom.l')}
    </div>
    <div class="th-bottom-r">{t('theory.bottom.r')}</div>
  </div>

</section>

<style>
/*════════════════════════════════════════════════
   THEORY SECTION
════════════════════════════════════════════════ */
#theory {
  width:100%;
  border-top:  1px solid var(--ink);
  border-bottom: 1px solid var(--ink);
}

/* ── Header row ─────────────────────────────── */
.th-header {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: stretch;
  border-bottom: 1px solid var(--ink);
  min-height: 44px;
}
.th-header-l {
  display: flex; align-items: center;
  padding: 0 32px;
  gap: 24px;
  border-right: 1px solid var(--ink);
}
.th-header-r {
  display: flex; align-items: center;
  padding: 0 28px;
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase; color: var(--mid);
  gap: 16px;
}
.th-section-tag {
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .30em; text-transform: uppercase; color: var(--mid);
}
.th-section-n {
  font-family: var(--f-mono); font-size: 8px; font-weight: 400;
  letter-spacing: .22em; text-transform: uppercase; color: var(--ink);
  border: 1px solid var(--ink);
  padding: 2px 8px;
}
/* colour dot indicators — show palette at a glance */
.th-dot-row { display: flex; gap: 6px; align-items: center; }
.th-dot { width: 8px; height: 8px; flex-shrink: 0; }

/* ── Main body ──────────────────────────────── */
.th-body {
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
}

/* ── Left column: title + intro + notes ──── */
.th-left {
  padding: 52px 48px 56px;
  display: flex; flex-direction: column; gap: 0;
}

.th-eyebrow {
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .32em; text-transform: uppercase; color: var(--mid);
  margin-bottom: 20px;
}
.th-title {
  font-family: var(--f-disp); font-size: clamp(28px, 3.2vw, 46px);
  font-weight: 800; line-height: .96; letter-spacing: -.025em;
  color: var(--ink); margin-bottom: 36px;
}
.th-title :global(em) { font-style: normal; font-weight: 400; color: var(--mid); }
.th-intro {
  font-size: clamp(13px, 1.05vw, 15.5px); font-weight: 400;
  line-height: 1.80; color: var(--mid);
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(20,18,16,.12);
  margin-bottom: 40px;
}
.th-intro :gloabal(em) { color: var(--ink); font-style: normal; font-weight: 600; }

/* Theory note blocks */
.th-notes { display: flex; flex-direction: column; gap: 32px; }
.th-note { display: grid; grid-template-columns: 3px 1fr; gap: 20px; }
.th-note-bar { }  /* colour set inline */
.th-note-content { }
.th-note-label {
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase; color: var(--mid);
  margin-bottom: 10px;
  display: flex; align-items: center; gap: 12px;
}
.th-note-label::after {
  content: ''; display: block; flex: 1; height: 1px;
  background: rgba(20,18,16,.1);
}
.th-note-title {
  font-family: var(--f-disp); font-size: clamp(13px, 1.1vw, 16px);
  font-weight: 700; color: var(--ink); margin-bottom: 10px; line-height: 1.2;
}
.th-note-body {
  font-size: clamp(12px, 0.9vw, 13.5px); font-weight: 400;
  line-height: 1.82; color: var(--mid);
}
.th-note-body :global(em) { color: var(--ink); font-style: normal; font-weight: 600; }

/* ── Vertical rule ──────────────────────────── */
.th-rule-v { background: var(--ink); }

/* ── Right column: geometric studies ───────── */
.th-right {
  display: flex; flex-direction: column;
}

/* Study 1 — nested squares (simultaneous contrast) */
.th-study {
  flex: 1;
  border-bottom: 1px solid var(--ink);
  display: flex; flex-direction: column;
  padding: 32px;
  gap: 20px;
  position: relative;
}
.th-study:last-child { border-bottom: none; }

.th-study-label {
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase; color: var(--mid);
  display: flex; justify-content: space-between;
}
.th-study-label span:last-child { color: var(--lt); }

/* Nested squares diagram */
.sq-diagram {
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  min-height: 180px;
  position: relative;
}
.sq-nest {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
/* Each nested square is positioned relative to the outer */
.sq-l0 { width: 160px; height: 160px; background: var(--teal); }
.sq-l1 { width: 121px; height: 121px; background: var(--ochre); }
.sq-l2 { width: 91px;  height: 91px;  background: var(--paper); }
.sq-l3 { width: 68px;  height: 68px;  background: var(--red); }
.sq-l4 { width: 51px;  height: 51px;  background: var(--teal); }

/* Offset variant for study 2 */
.sq-nest-offset { position: relative; width: 160px; height: 160px; }
.sq-offset-a {
  position: absolute; inset: 0;
  background: var(--ink);
}
.sq-offset-b {
  position: absolute; top: 24px; left: 24px;
  width: 112px; height: 112px;
  background: var(--teal);
}
.sq-offset-c {
  position: absolute; top: 48px; left: 48px;
  width: 80px; height: 80px;
  background: var(--ochre);
}
.sq-offset-d {
  position: absolute; top: 68px; left: 68px;
  width: 44px; height: 44px;
  background: var(--red);
}

/* Color field study — same grey on different grounds */
.field-row {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
  height: 100px;
  border: 1px solid var(--ink);
}
.field-cell {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  border-right: 1px solid var(--ink);
}
.field-cell:last-child { border-right: none; }
.field-centre {
  width: 20px; height: 20px;
  background: #A09890; /* same value in every cell */
  flex-shrink: 0;
}
.field-cell:nth-child(1) { background: var(--teal); }
.field-cell:nth-child(2) { background: var(--ochre); }
.field-cell:nth-child(3) { background: var(--paper); }
.field-cell:nth-child(4) { background: var(--ink); }
.field-note {
  font-family: var(--f-mono); font-size: 7px; font-weight: 300;
  letter-spacing: .24em; text-transform: uppercase; color: var(--mid);
  text-align: center; line-height: 1.6;
}

/* Study 3 — grid tension: 3×3 grid, one displaced cell */
.grid-study {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  width: 150px;
}
.gs-cell {
  aspect-ratio: 1;
  background: var(--lt);
}
.gs-cell.displaced {
  background: var(--red);
  transform: translate(4px, -4px);
}
.gs-cell.accent { background: var(--teal); }

/* Footer strip inside right column */
.th-study-foot {
  font-family: var(--f-mono); font-size: 7px; font-weight: 300;
  letter-spacing: .22em; text-transform: uppercase; color: var(--lt);
  margin-top: auto; padding-top: 14px;
  border-top: 1px solid rgba(20,18,16,.1);
  line-height: 1.8;
}

/* ── Bottom bar ─────────────────────────────── */
.th-bottom {
  display: grid; grid-template-columns: 1fr auto;
  border-top: 1px solid var(--ink);
  min-height: 40px;
  align-items: center;
}
.th-bottom-l {
  padding: 0 32px;
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase; color: var(--mid);
  border-right: 1px solid var(--ink);
  height: 100%; display: flex; align-items: center;
}
.th-bottom-r {
  padding: 0 28px;
  font-family: var(--f-mono); font-size: 8px; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase; color: var(--mid);
}

/* ── Responsive ────────────────────────────── */
@media (max-width: 860px) {
  .th-body { grid-template-columns: 1fr; }
  .th-rule-v { display: none; }
  .th-right { border-top: 1px solid var(--ink); }
  .th-study { flex-direction: row; flex-wrap: wrap; gap: 24px; align-items: flex-start; }
  .sq-diagram { min-height: 140px; justify-content: flex-start; }
  .th-header { grid-template-columns: 1fr; }
  .th-header-r { display: none; }
  .th-header-l { border-right: none; }
}
@media (max-width: 560px) {
  .th-left { padding: 36px 24px 40px; }
  .th-study { padding: 24px; }
  .th-bottom { grid-template-columns: 1fr; }
  .th-bottom-l { border-right: none; border-bottom: 1px solid rgba(20,18,16,.12); }
}
</style>