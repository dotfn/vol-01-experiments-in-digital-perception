---
import { useTranslations } from '../i18n/utils';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero">

  <!-- LEFT FIELD — dark teal -->
  <div class="h-left">
    <div class="h-left-top" id="field-teal">
      <span class="color-label on-dark">{t('hero.field.teal')}<br>— Teal</span>
      <span class="color-label on-dark">{t('hero.field.001')}</span>
      <div class="field-sq" id="sq-teal"></div>
    </div>
    <div class="h-left-bot" id="field-ochre">
      <span class="color-label on-ochre">{t('hero.field.ochre')}&nbsp;{t('hero.field.002')}</span>
    </div>
  </div>

  <!-- CENTER — name and statements -->
  <div class="h-center">
    <div class="h-name-row">
      <span class="h-name" set:html={t('hero.name')}></span>
      <div class="h-name-sub">
        <span class="h-tag">{t('hero.tag.perception')}</span>
        <span class="h-tag">{t('hero.tag.design')}</span>
        <span class="h-tag">{t('hero.tag.interaction')}</span>
        <span class="h-tag">{t('hero.tag.color')}</span>
      </div>
    </div>
    <div class="h-statement-row">
      <div class="h-stmt-a">
        <div>
          <div class="stmt-num">{t('hero.stmt01.num')}</div>
          <p class="stmt-body">{t('hero.stmt01.body')}</p>
        </div>
        <span class="mono" style="color:var(--mid)">{t('hero.stmt01.sub')}</span>
      </div>
      <div style="background:var(--ink);width:1px;"></div>
      <div class="h-stmt-b">
        <div>
          <div class="stmt-num-inv">{t('hero.stmt02.num')}</div>
          <p class="stmt-body-inv">{t('hero.stmt02.body')}</p>
        </div>
        <span class="mono on-dark">{t('hero.stmt02.sub')}</span>
      </div>
    </div>
  </div>

  <!-- RIGHT FIELD — red -->
  <div class="h-right">
    <div class="h-right-top" id="field-red">
      <span class="color-label on-red">{t('hero.field.red')}&nbsp;{t('hero.field.003')}</span>
      <span class="color-label on-red">{t('hero.field.practice')}<br>{t('hero.field.practice.dates')}</span>
    </div>
    <div class="h-right-bot" id="field-lt">
      <span class="color-label on-lt">{t('hero.field.lt')}</span>
    </div>
  </div>

</section>

<style>

/* ═══════════════════════════════════════
   HERO — flat color composition
   The name cuts across two color fields.
   Adjacent colors create perception shift.
   ═══════════════════════════════════════ */
#hero {
  width:100%;
  display:grid;
  grid-template-columns: 280px 1fr 280px;
  grid-template-rows: auto 1fr;
  border-bottom: 1px solid var(--ink);
}

/* Left column */
.h-left {
  grid-column:1; grid-row:1/3;
  border-right:1px solid var(--ink);
  display:flex; flex-direction:column;
}
.h-left-top {
  background: var(--teal);
  flex:1; padding:32px 28px;
  display:flex; flex-direction:column; justify-content:space-between;
  border-bottom:1px solid var(--ink);
  position:relative; overflow:hidden;
  transition: background .6s ease;
}
.h-left-top .field-sq {
  position:absolute; bottom:24px; right:24px;
  width:64px; height:64px; background:var(--ochre);
  transition: transform .5s ease, background .6s ease;
}
.h-left-bot {
  background: var(--ochre);
  padding:28px;
  transition: background .6s ease;
}

/* Center column */
.h-center {
  grid-column:2; grid-row:1/3;
  display:flex; flex-direction:column;
  border-right:1px solid var(--ink);
}
.h-name-row {
  padding: 40px 48px 28px;
  border-bottom:1px solid var(--ink);
}
.h-name {
  font-family: var(--f-disp); font-weight:800;
  font-size: clamp(36px, 5vw, 80px);
  line-height:.92; letter-spacing:-.03em;
  color: var(--ink);
  display:block;
}
.h-name-sub {
  margin-top:20px;
  font-family:var(--f-mono); font-size:9px; font-weight:300;
  letter-spacing:.30em; text-transform:uppercase; color:var(--mid);
  display:flex; gap:24px; flex-wrap:wrap;
}
.h-tag { display:flex; gap:8px; align-items:center; }
.h-tag::before { content:''; display:block; width:16px; height:1px; background:var(--mid); }

.h-statement-row {
  flex:1; display:grid; grid-template-columns:1fr 1px 1fr;
}
.h-stmt-a {
  padding:40px 48px;
  display:flex; flex-direction:column; justify-content:space-between;
}
.h-stmt-b {
  background:var(--ink);
  padding:40px 48px;
  display:flex; flex-direction:column; justify-content:space-between;
}
.stmt-body {
  font-size: clamp(12px, 1vw, 15px); font-weight:400; line-height:1.72;
  color: var(--mid);
}
.stmt-body-inv {
  font-size: clamp(12px, 1vw, 15px); font-weight:400; line-height:1.72;
  color: rgba(236,234,227,.52);
}
.stmt-num {
  font-family:var(--f-mono); font-size:clamp(36px, 4.5vw, 64px); font-weight:300;
  line-height:1; color:rgba(20,18,16,.06); user-select:none;
  margin-bottom:16px;
}
.stmt-num-inv {
  font-family:var(--f-mono); font-size:clamp(36px, 4.5vw, 64px); font-weight:300;
  line-height:1; color:rgb(62 62 62 / 58%); user-select:none;
  margin-bottom:16px;
}

/* Right column */
.h-right {
  grid-column:3; grid-row:1/3;
  display:flex; flex-direction:column;
}
.h-right-top {
  background: var(--red);
  flex:1; padding:32px 28px;
  display:flex; flex-direction:column; justify-content:space-between;
  border-bottom:1px solid var(--ink);
  position:relative; overflow:hidden;
  transition: background .6s ease;
}
.h-right-top::after {
  content:''; position:absolute; top:24px; left:24px;
  width:32px; height:32px; border:1px solid rgba(236,234,227,.28);
  transition: transform .5s ease;
}
.h-right-bot {
  background: var(--lt);
  padding:28px;
  transition: background .6s ease;
}

.color-label {
  font-family:var(--f-mono); font-size:8px; font-weight:300;
  letter-spacing:.28em; text-transform:uppercase;
}
.on-dark  { color:rgba(236,234,227,.45); }
.on-ochre { color:rgba(20,18,16,.52); }
.on-red   { color:rgba(236,234,227,.45); }
.on-lt    { color:rgba(20,18,16,.40); }

@media (max-width: 900px) {
      #hero {
      grid-template-columns: 1fr;
    }
    .h-left,
    .h-right {
      display: none;
    }
    .h-center {
      border-right: none;
    }
    .h-statement-row {
      grid-template-columns: 1fr;
    }
}

</style>

<script>
const fieldTeal = document.getElementById('field-teal');
const fieldRed = document.getElementById('field-red');
const fieldLt = document.getElementById('field-lt');
const sqTeal = document.getElementById('sq-teal');

fieldTeal?.addEventListener('mouseenter', () => { sqTeal.style.transform = 'translate(-6px,-6px)'; });
fieldTeal?.addEventListener('mouseleave', () => { sqTeal.style.transform = ''; });

fieldRed?.addEventListener('mouseenter', () => { fieldLt.style.background = '#C8C3BC'; });
fieldRed?.addEventListener('mouseleave', () => { fieldLt.style.background = ''; });

</script>