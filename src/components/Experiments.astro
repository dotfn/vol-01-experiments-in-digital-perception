---
import { useTranslations } from '../i18n/utils';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<!-- ═══ EXPERIMENTS ══════════════════════════════════════ -->
<section id="experiments">

  {[1, 2, 3, 4].map((n) => {
    const k = String(n).padStart(2, '0');
    return (
      <div class="exp-col" id={`ec${n}`}>
        <div class="exp-canvas-block">
          <canvas id={`exp${n}`}></canvas>
          <div class="exp-c-label">{t(`exp.${k}.label`)}</div>
        </div>
        <div class="exp-info">
          <div>
            <div class="exp-n">{t(`exp.${k}.num`)}</div>
            <h3 class="exp-title" set:html={t(`exp.${k}.title`)}></h3>
            <p class="exp-desc">{t(`exp.${k}.desc`)}</p>
          </div>
        </div>
      </div>
    );
  })}

</section>

<style>
  #experiments {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--ink);
  }
  .exp-col {
    border-right: 1px solid var(--ink);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(20px);
    /* All transitions defined once — avoids overriding shorthand later */
    transition:
      opacity 1s ease,
      transform 1s ease,
      background 0.35s ease;
  }
  .exp-col:last-child { border-right: none; }
  .exp-col.vis        { opacity: 1; transform: none; }

  .exp-col:nth-child(2) { transition-delay: 0.1s; }
  .exp-col:nth-child(3) { transition-delay: 0.2s; }
  .exp-col:nth-child(4) { transition-delay: 0.3s; }

  .exp-canvas-block {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-bottom: 1px solid var(--ink);
    overflow: hidden;
    position: relative;
    touch-action: pan-y;
  }
  .exp-canvas-block canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .exp-c-label {
    position: absolute;
    bottom: 10px;
    left: 12px;
    font-family: var(--f-mono);
    font-size: 7.5px;
    font-weight: 300;
    letter-spacing: 0.25em;
    color: rgba(236, 234, 227, 0.22);
    text-transform: uppercase;
    pointer-events: none;
  }

  .exp-info {
    padding: 20px 24px 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .exp-n {
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 10px;
  }
  .exp-title {
    font-family: var(--f-disp);
    font-size: clamp(13px, 1.1vw, 17px);
    font-weight: 700;
    line-height: 1.18;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .exp-title :global(em) {
    font-style: normal;
    font-weight: 400;
    color: var(--mid);
  }
  .exp-desc {
    font-size: clamp(10px, 0.85vw, 13px);
    font-weight: 400;
    line-height: 1.72;
    color: var(--mid);
  }

  /* ── Per-column hover themes ────────────────────────────────────────────── */
  .exp-col:nth-child(1):hover { background: var(--teal); }
  .exp-col:nth-child(1):hover .exp-title,
  .exp-col:nth-child(1):hover .exp-desc { color: rgba(236, 234, 227, 0.7); }
  .exp-col:nth-child(1):hover .exp-n    { color: rgba(236, 234, 227, 0.35); }

  .exp-col:nth-child(2):hover { background: var(--ochre); }
  .exp-col:nth-child(2):hover .exp-title { color: rgba(20, 18, 16, 0.9); }
  .exp-col:nth-child(2):hover .exp-desc,
  .exp-col:nth-child(2):hover .exp-n     { color: rgba(20, 18, 16, 0.55); }

  .exp-col:nth-child(3):hover { background: var(--ink); }
  .exp-col:nth-child(3):hover .exp-title,
  .exp-col:nth-child(3):hover .exp-desc { color: rgba(236, 234, 227, 0.7); }
  .exp-col:nth-child(3):hover .exp-n    { color: rgba(236, 234, 227, 0.35); }

  .exp-col:nth-child(4):hover { background: var(--red); }
  .exp-col:nth-child(4):hover .exp-title { color: rgba(236, 234, 227, 0.95); }
  .exp-col:nth-child(4):hover .exp-desc,
  .exp-col:nth-child(4):hover .exp-n     { color: rgba(236, 234, 227, 0.55); }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    #experiments { grid-template-columns: 1fr 1fr; }
    .section-div { grid-template-columns: 1fr; }
    .sd-a, .sd-c { display: none; }
    .sd-b        { border-right: none; }
  }
  @media (max-width: 560px) {
    #experiments { grid-template-columns: 1fr; }
    .exp-col {
      border-right: none;
      border-bottom: 1px solid var(--ink);
    }
  }
</style>

<script>
import { DividedField }        from '../scripts/experiments/DividedField.js';
import { RepulsionGrid }       from '../scripts/experiments/RepulsionGrid.js';
import { MondrianSplit }       from '../scripts/experiments/MondrianSplit.js';
import { StackedSquares }      from '../scripts/experiments/StackedSquares.js';
import { observeVisibility }   from '../scripts/observeVisibility.js';

// ── Boot experiments ─────────────────────────────────────────────────────────
new DividedField();
new RepulsionGrid();
new MondrianSplit();
new StackedSquares();

// ── Scroll-in animation for the grid columns ─────────────────────────────────
observeVisibility('#experiments, .exp-col');
</script>