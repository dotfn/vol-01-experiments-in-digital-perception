  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background-color: #eceae3;
    background-image: url("/beige-paper.png");
    color: var(--ink);
    font-family: var(--f-body);
    font-size: 18px;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  /* ── NAV ─────────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 40px;
    padding: 0 var(--pad-x);
    background: var(--ink);
    border-bottom: 1px solid #2a2826;
  }
  .nav-home {
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-home:hover {
    color: var(--paper);
  }
  .nav-path {
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: lowercase;
    color: rgba(236, 234, 227, 0.3);
  }
  .nav-tag {
    font-family: var(--f-mono);
    font-size: 8px;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mid);
    text-align: right;
    border: 1px solid #2a2826;
