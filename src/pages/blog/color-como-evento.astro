    --paper: #eceae3;
    --ink: #141210;
    --ochre: #c49520;
    --red: #c03b24;
    --teal: #1e3835;
    --lt: #8a8a8a;
    --mid: #8a857e;
    --f-disp: "Syne", sans-serif;
    --f-mono: "IBM Plex Mono", monospace;
    --f-body: "EB Garamond", Georgia, serif;
    --col: 680px;
    --pad-x: clamp(20px, 5vw, 60px);
  }

  /* ── RESET ───────────────────────────────────────────── */
